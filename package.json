{
  "name": "kube-helper",
  "version": "0.1.0",
  "description": "Plug-and-play container orchestration for a single machine — the useful parts of Kubernetes on plain Docker.",
  "author": "mannilakash",
  "type": "module",
  "main": "dist/electron/main.js",
  "bin": {
    "kh": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "package": "node scripts/package.mjs",
    "gui:build": "node scripts/build-gui.mjs && tsc -p tsconfig.gui.json",
    "gui": "npm run build && npm run gui:build && electron .",
    "dist": "npm run build && npm run gui:build && electron-builder --win"
  },
  "build": {
    "appId": "dev.kubehelper.desktop",
    "productName": "kube-helper",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "npmRebuild": false
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "dockerode": "^5.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/node": "^26.1.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
